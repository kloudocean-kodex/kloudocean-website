# Normalize line endings across OS
* text=auto
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.svg text eol=lf

# Ensure binary assets are treated as binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
